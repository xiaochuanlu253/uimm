library(pacsurv)
library(uimm)
set.seed(1)
n <- 200
df <- data.frame(
birthage = runif(n, 80, 90),
censoredage = runif(n, 90, 105),
DthIndicator = rbinom(n, 1, 0.4)
)
fit <- pac_fit(Surv(birthage, censoredage, DthIndicator) ~ 1, data = df, AC = "Gompertz", patience = 50)
library(survival)
fit <- pac_fit(Surv(birthage, censoredage, DthIndicator) ~ 1, data = df, AC = "Gompertz", patience = 50)
fit
AIC(fit)
